<!DOCTYPE html><html lang="en"><head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title data-id="th-modified">Student Government Association — Drew University</title>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,500;0,9..144,700;1,9..144,300&amp;family=Plus+Jakarta+Sans:wght@400;500;600;700&amp;display=swap" rel="stylesheet">
  <style>
    :root {
      --forest:    #1b3d2f;
      --forest-2:  #244d3c;
      --forest-3:  #2e5e49;
      --gold:      #c9a84c;
      --gold-pale: #f0e4c0;
      --gold-dim:  rgba(201,168,76,0.15);
      --bg:        #f2ede4;
      --surface:   #faf7f2;
      --border:    #ddd5c4;
      --text:      #1a1a18;
      --muted:     #7a7265;
      --accent:    #3b6e56;
      --green:     #2a6e47;
      --red:       #b94040;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'Plus Jakarta Sans', sans-serif;
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
    }

    a { color: inherit; text-decoration: none; }

    /* ───────────────────── TOP BAR ───────────────────── */
    .topbar {
      background: var(--forest);
      color: #fff;
      padding: 0 2rem;
      height: 58px;
      display: flex;
      align-items: center;
      gap: 1rem;
      border-bottom: 3px solid var(--gold);
      position: sticky;
      top: 0;
      z-index: 100;
    }

    .topbar-logo {
      font-family: 'Fraunces', serif;
      font-size: 1.2rem;
      font-weight: 700;
      color: #fff;
      letter-spacing: -0.01em;
      white-space: nowrap;
    }
    .topbar-logo span { color: var(--gold); }

    .topbar-divider {
      width: 1px;
      height: 22px;
      background: rgba(255,255,255,0.2);
      flex-shrink: 0;
    }

    .topbar-sub {
      font-size: 0.78rem;
      color: rgba(255,255,255,0.55);
      font-weight: 500;
      letter-spacing: 0.04em;
      white-space: nowrap;
    }

    nav {
      margin-left: auto;
      display: flex;
      align-items: center;
      gap: 0.25rem;
    }

    nav a {
      font-size: 0.8rem;
      font-weight: 600;
      color: rgba(255,255,255,0.7);
      padding: 0.4rem 0.85rem;
      border-radius: 6px;
      transition: background 0.15s, color 0.15s;
      letter-spacing: 0.02em;
    }

    nav a:hover { background: rgba(255,255,255,0.1); color: #fff; }

    .nav-cta {
      background: var(--gold) !important;
      color: var(--forest) !important;
      font-weight: 700 !important;
      border-radius: 6px;
      padding: 0.4rem 1rem !important;
      transition: opacity 0.15s !important;
    }
    .nav-cta:hover { opacity: 0.88; background: var(--gold) !important; }

    .nav-hamburger {
      display: none;
      background: none;
      border: none;
      cursor: pointer;
      padding: 4px;
      margin-left: auto;
      color: #fff;
    }

    /* ───────────────────── HERO ───────────────────── */
    .hero {
      background: linear-gradient(140deg, var(--forest) 0%, var(--forest-2) 55%, #1a3828 100%);
      color: #fff;
      padding: 5rem 2rem 4.5rem;
      text-align: center;
      position: relative;
      overflow: hidden;
    }

    .hero::before {
      content: '';
      position: absolute;
      inset: 0;
      background:
        radial-gradient(ellipse at 75% -10%, rgba(201,168,76,0.18) 0%, transparent 55%),
        radial-gradient(ellipse at 10% 110%, rgba(59,110,86,0.3) 0%, transparent 50%);
      pointer-events: none;
    }

    /* subtle grid overlay */
    .hero::after {
      content: '';
      position: absolute;
      inset: 0;
      background-image:
        linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);
      background-size: 40px 40px;
      pointer-events: none;
    }

    .hero-inner {
      position: relative;
      z-index: 1;
      max-width: 720px;
      margin: 0 auto;
    }

    .hero-eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--gold);
      background: rgba(201,168,76,0.12);
      border: 1px solid rgba(201,168,76,0.3);
      border-radius: 20px;
      padding: 0.35rem 1rem;
      margin-bottom: 1.5rem;
    }

    .hero h1 {
      font-family: 'Fraunces', serif;
      font-size: clamp(2.4rem, 6vw, 3.8rem);
      font-weight: 500;
      line-height: 1.1;
      letter-spacing: -0.025em;
      margin-bottom: 1.25rem;
    }

    .hero h1 em {
      font-style: italic;
      color: var(--gold);
    }

    .hero-sub {
      font-size: 1.05rem;
      color: rgba(255,255,255,0.68);
      max-width: 500px;
      margin: 0 auto 2.5rem;
      line-height: 1.7;
    }

    .hero-actions {
      display: flex;
      gap: 0.85rem;
      justify-content: center;
      flex-wrap: wrap;
    }

    .btn-hero-primary {
      background: var(--gold);
      color: var(--forest);
      border: none;
      border-radius: 8px;
      padding: 0.85rem 2.25rem;
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 0.9rem;
      font-weight: 700;
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      transition: opacity 0.15s, transform 0.1s;
    }
    .btn-hero-primary:hover { opacity: 0.88; transform: translateY(-1px); }

    .btn-hero-secondary {
      background: rgba(255,255,255,0.1);
      color: #fff;
      border: 1.5px solid rgba(255,255,255,0.25);
      border-radius: 8px;
      padding: 0.85rem 2rem;
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 0.9rem;
      font-weight: 600;
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      transition: background 0.15s, transform 0.1s;
    }
    .btn-hero-secondary:hover { background: rgba(255,255,255,0.18); transform: translateY(-1px); }

    /* ───────────────────── STATS STRIP ───────────────────── */
    .stats-strip {
      background: var(--gold-pale);
      border-bottom: 1px solid var(--border);
      padding: 1.25rem 2rem;
      display: flex;
      justify-content: center;
      gap: 0;
    }

    .stat-item {
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 0 2.5rem;
      border-right: 1px solid var(--border);
    }
    .stat-item:last-child { border-right: none; }

    .stat-num {
      font-family: 'Fraunces', serif;
      font-size: 1.9rem;
      font-weight: 700;
      color: var(--forest);
      line-height: 1;
    }

    .stat-label {
      font-size: 0.72rem;
      font-weight: 600;
      color: var(--muted);
      letter-spacing: 0.06em;
      text-transform: uppercase;
      margin-top: 0.25rem;
    }

    /* ───────────────────── PAGE LAYOUT ───────────────────── */
    .page {
      max-width: 1100px;
      margin: 0 auto;
      padding: 3.5rem 1.5rem 5rem;
    }

    /* ───────────────────── SECTION LABEL ───────────────────── */
    .section-label {
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--accent);
      display: flex;
      align-items: center;
      gap: 0.75rem;
      margin-bottom: 1.5rem;
    }
    .section-label::after {
      content: '';
      flex: 1;
      height: 1px;
      background: var(--border);
    }

    /* ───────────────────── CARDS ───────────────────── */
    .card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 12px;
      box-shadow: 0 2px 20px rgba(27,61,47,0.07);
      overflow: hidden;
    }

    .card-header {
      padding: 1.4rem 2rem 1.2rem;
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      gap: 1rem;
    }

    .card-icon {
      width: 40px;
      height: 40px;
      border-radius: 10px;
      background: var(--gold-pale);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    .card-header h2 {
      font-family: 'Fraunces', serif;
      font-size: 1.2rem;
      font-weight: 500;
      color: var(--forest);
    }

    .card-header p {
      font-size: 0.8rem;
      color: var(--muted);
      margin-top: 2px;
    }

    .card-body { padding: 2rem; }

    /* ───────────────────── ANNOUNCEMENTS ───────────────────── */
    .announcements-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.25rem;
      margin-bottom: 3.5rem;
    }

    .announcement-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 12px;
      box-shadow: 0 2px 12px rgba(27,61,47,0.06);
      overflow: hidden;
      display: flex;
      flex-direction: column;
      transition: box-shadow 0.2s, transform 0.15s;
    }
    .announcement-card:hover { box-shadow: 0 6px 24px rgba(27,61,47,0.12); transform: translateY(-2px); }

    .announcement-card.featured {
      grid-column: 1 / -1;
      flex-direction: row;
    }

    .announcement-img {
      background: linear-gradient(135deg, var(--forest) 0%, var(--accent) 100%);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    .announcement-card:not(.featured) .announcement-img {
      height: 130px;
    }

    .announcement-card.featured .announcement-img {
      width: 300px;
      min-height: 220px;
    }

    .announcement-img svg { opacity: 0.3; }

    .announcement-content {
      padding: 1.5rem;
      flex: 1;
      display: flex;
      flex-direction: column;
    }

    .ann-meta {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      margin-bottom: 0.6rem;
      flex-wrap: wrap;
    }

    .ann-tag {
      font-size: 0.65rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      background: var(--gold-pale);
      color: var(--forest);
      border: 1px solid rgba(201,168,76,0.4);
      border-radius: 4px;
      padding: 2px 7px;
    }

    .ann-tag.urgent {
      background: #fdeaea;
      color: var(--red);
      border-color: rgba(185,64,64,0.3);
    }

    .ann-tag.new {
      background: #e6f4ec;
      color: var(--green);
      border-color: rgba(42,110,71,0.3);
    }

    .ann-date {
      font-size: 0.72rem;
      color: var(--muted);
      font-weight: 500;
    }

    .announcement-content h3 {
      font-family: 'Fraunces', serif;
      font-size: 1.15rem;
      font-weight: 500;
      color: var(--forest);
      line-height: 1.3;
      margin-bottom: 0.5rem;
    }

    .announcement-card.featured .announcement-content h3 {
      font-size: 1.5rem;
    }

    .announcement-content p {
      font-size: 0.85rem;
      color: var(--muted);
      line-height: 1.65;
      flex: 1;
    }

    .ann-link {
      display: inline-flex;
      align-items: center;
      gap: 0.3rem;
      font-size: 0.8rem;
      font-weight: 600;
      color: var(--accent);
      margin-top: 1rem;
      transition: gap 0.15s;
    }
    .ann-link:hover { gap: 0.5rem; }

    /* ───────────────────── TWO-COL LAYOUT ───────────────────── */
    .two-col {
      display: grid;
      grid-template-columns: 1fr 340px;
      gap: 1.5rem;
      margin-bottom: 3.5rem;
    }

    /* ───────────────────── MEETINGS ───────────────────── */
    .meetings-list {
      display: flex;
      flex-direction: column;
      gap: 0;
    }

    .meeting-item {
      display: flex;
      gap: 1rem;
      align-items: flex-start;
      padding: 1.1rem 0;
      border-bottom: 1px solid var(--border);
    }
    .meeting-item:last-child { border-bottom: none; }

    .meeting-date-box {
      width: 50px;
      flex-shrink: 0;
      background: var(--forest);
      color: #fff;
      border-radius: 8px;
      text-align: center;
      padding: 6px 4px;
    }

    .meeting-date-box .month {
      font-size: 0.6rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--gold);
    }

    .meeting-date-box .day {
      font-family: 'Fraunces', serif;
      font-size: 1.5rem;
      font-weight: 700;
      line-height: 1;
    }

    .meeting-info { flex: 1; }

    .meeting-info h4 {
      font-size: 0.9rem;
      font-weight: 700;
      color: var(--forest);
      margin-bottom: 0.2rem;
    }

    .meeting-info p {
      font-size: 0.78rem;
      color: var(--muted);
      line-height: 1.5;
    }

    .meeting-badge {
      font-size: 0.65rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      padding: 2px 8px;
      border-radius: 20px;
      white-space: nowrap;
      margin-top: 4px;
      display: inline-block;
    }
    .meeting-badge.open { background: #e6f4ec; color: var(--green); }
    .meeting-badge.members { background: var(--gold-pale); color: #7a5c10; }

    /* ───────────────────── QUICK LINKS SIDEBAR ───────────────────── */
    .quick-links-list {
      display: flex;
      flex-direction: column;
      gap: 0;
    }

    .quick-link-item {
      display: flex;
      align-items: center;
      gap: 0.85rem;
      padding: 0.9rem 0;
      border-bottom: 1px solid var(--border);
      transition: padding-left 0.15s;
      cursor: pointer;
    }
    .quick-link-item:last-child { border-bottom: none; }
    .quick-link-item:hover { padding-left: 4px; }

    .ql-icon {
      width: 34px;
      height: 34px;
      border-radius: 8px;
      background: var(--gold-pale);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    .ql-label {
      font-size: 0.88rem;
      font-weight: 600;
      color: var(--forest);
    }

    .ql-desc {
      font-size: 0.75rem;
      color: var(--muted);
      margin-top: 1px;
    }

    .ql-arrow {
      margin-left: auto;
      color: var(--muted);
      flex-shrink: 0;
    }

    /* ───────────────────── MEMBERS / OFFICERS ───────────────────── */
    .officers-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1rem;
      margin-bottom: 3.5rem;
    }

    .officer-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 1.5rem 1rem;
      text-align: center;
      box-shadow: 0 2px 12px rgba(27,61,47,0.06);
      transition: box-shadow 0.2s, transform 0.15s;
    }
    .officer-card:hover { box-shadow: 0 6px 24px rgba(27,61,47,0.12); transform: translateY(-2px); }

    .officer-avatar {
      width: 64px;
      height: 64px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--forest) 0%, var(--accent) 100%);
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 1rem;
      font-family: 'Fraunces', serif;
      font-size: 1.35rem;
      font-weight: 700;
      color: #fff;
      border: 3px solid var(--gold-pale);
    }

    .officer-name {
      font-family: 'Fraunces', serif;
      font-size: 1rem;
      font-weight: 500;
      color: var(--forest);
      margin-bottom: 0.2rem;
    }

    .officer-title {
      font-size: 0.72rem;
      font-weight: 600;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--muted);
    }

    .officer-email {
      font-size: 0.73rem;
      color: var(--accent);
      margin-top: 0.5rem;
    }

    /* ───────────────────── INITIATIVES ───────────────────── */
    .initiatives-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1rem;
      margin-bottom: 3.5rem;
    }

    .initiative-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 1.75rem 1.5rem;
      box-shadow: 0 2px 12px rgba(27,61,47,0.06);
      transition: box-shadow 0.2s, transform 0.15s;
    }
    .initiative-card:hover { box-shadow: 0 6px 24px rgba(27,61,47,0.12); transform: translateY(-2px); }

    .initiative-icon {
      width: 46px;
      height: 46px;
      border-radius: 10px;
      background: var(--gold-pale);
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 1.25rem;
    }

    .initiative-card h3 {
      font-family: 'Fraunces', serif;
      font-size: 1.05rem;
      font-weight: 500;
      color: var(--forest);
      margin-bottom: 0.5rem;
      line-height: 1.3;
    }

    .initiative-card p {
      font-size: 0.83rem;
      color: var(--muted);
      line-height: 1.65;
    }

    .initiative-status {
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      margin-top: 1rem;
      font-size: 0.72rem;
      font-weight: 600;
      color: var(--green);
    }

    .initiative-status::before {
      content: '';
      width: 7px;
      height: 7px;
      background: var(--green);
      border-radius: 50%;
    }

    .initiative-status.pending { color: #b58a1a; }
    .initiative-status.pending::before { background: #b58a1a; }

    /* ───────────────────── CTA BANNER ───────────────────── */
    .cta-banner {
      background: linear-gradient(135deg, var(--forest) 0%, var(--forest-3) 100%);
      border-radius: 16px;
      padding: 3rem 2.5rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 2rem;
      margin-bottom: 3.5rem;
      position: relative;
      overflow: hidden;
    }

    .cta-banner::before {
      content: '';
      position: absolute;
      right: -60px;
      top: -60px;
      width: 280px;
      height: 280px;
      border-radius: 50%;
      background: rgba(201,168,76,0.12);
      pointer-events: none;
    }

    .cta-text { position: relative; z-index: 1; }

    .cta-text h2 {
      font-family: 'Fraunces', serif;
      font-size: 1.7rem;
      font-weight: 500;
      color: #fff;
      margin-bottom: 0.6rem;
      line-height: 1.2;
    }

    .cta-text h2 em { color: var(--gold); font-style: italic; }

    .cta-text p {
      font-size: 0.9rem;
      color: rgba(255,255,255,0.65);
      max-width: 400px;
      line-height: 1.65;
    }

    .cta-actions {
      display: flex;
      gap: 0.75rem;
      flex-shrink: 0;
      flex-wrap: wrap;
      position: relative;
      z-index: 1;
    }

    .btn-primary {
      background: var(--gold);
      color: var(--forest);
      border: none;
      border-radius: 8px;
      padding: 0.8rem 1.75rem;
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 0.88rem;
      font-weight: 700;
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      transition: opacity 0.15s, transform 0.1s;
    }
    .btn-primary:hover { opacity: 0.88; transform: translateY(-1px); }

    .btn-secondary {
      background: rgba(255,255,255,0.1);
      color: #fff;
      border: 1.5px solid rgba(255,255,255,0.25);
      border-radius: 8px;
      padding: 0.8rem 1.5rem;
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 0.88rem;
      font-weight: 600;
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      transition: background 0.15s;
    }
    .btn-secondary:hover { background: rgba(255,255,255,0.18); }

    /* ───────────────────── FOOTER ───────────────────── */
    footer {
      background: var(--forest);
      color: rgba(255,255,255,0.6);
      padding: 3rem 2rem 2rem;
      border-top: 3px solid var(--gold);
    }

    .footer-inner {
      max-width: 1100px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1.5fr 1fr 1fr 1fr;
      gap: 2.5rem;
      margin-bottom: 2.5rem;
    }

    .footer-brand h3 {
      font-family: 'Fraunces', serif;
      font-size: 1.1rem;
      font-weight: 700;
      color: #fff;
      margin-bottom: 0.5rem;
    }

    .footer-brand h3 span { color: var(--gold); }

    .footer-brand p {
      font-size: 0.8rem;
      line-height: 1.65;
      max-width: 220px;
    }

    .footer-col h4 {
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 1rem;
    }

    .footer-col ul {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 0.55rem;
    }

    .footer-col ul li a {
      font-size: 0.83rem;
      color: rgba(255,255,255,0.6);
      transition: color 0.15s;
    }
    .footer-col ul li a:hover { color: #fff; }

    .footer-bottom {
      max-width: 1100px;
      margin: 0 auto;
      padding-top: 1.5rem;
